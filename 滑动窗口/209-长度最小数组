from typing import List

class Solution:
    def minSubArrayLen(self, target: int, nums: List[int]) -> int:
        """
        不满足时快指针探路,条件满足满指针收缩,直到不满足,记录最小长度
        子数组,连续的,正整数(>0),滑动窗口,双指针
        """
        slow = 0
        fast = 0
        sum = 0
        min_len = float('inf')
        while fast < len(nums):
            sum += nums[fast]
            while sum >= target:
                min_len = min(min_len, fast - slow)
                sum -= nums[slow]
                slow += 1
            fast += 1
        return min_len  if min_len != float('inf') else 0
