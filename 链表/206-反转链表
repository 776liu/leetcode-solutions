#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution(object):
    def reverseList(self, head):
        """
        :type head: Optional[ListNode]
        :rtype: Optional[ListNode]
        """

        cur = None
        while head != None:
            cur = ListNode(head.val, cur)
            head = head.next

        return cur
    
    def reverseList2(self, head):
        # 原地反转
        pre = None
        while head != None:
            next = head.next
            head.next = pre
            pre = head
            head = next
        return pre
            

            
            

            


